import runtime;
import math/bits;
import string;

export {
	sha256(input : string) -> string;
	hmacSha256(input : string, key : string) -> string;
}

native sha256Native : (input : string) -> string = FlowCrypto.sha256;
sha256Native(input : string) -> string {
	msg = "Warning: sha256Native is not implemented for this target.";
	println(msg);
	sha256HexFromBytes(string2utf8(input));
}

sha256(input : string) -> string {
	sha256Native(input)
}

sha256Init : [int] = [
	0x6A09E667,
	0xBB67AE85,
	0x3C6EF372,
	0xA54FF53A,
	0x510E527F,
	0x9B05688C,
	0x1F83D9AB,
	0x5BE0CD19
];

sha256K : [int] = [
	0x428A2F98, 0x71374491, 0xB5C0FBCF, 0xE9B5DBA5,
	0x3956C25B, 0x59F111F1, 0x923F82A4, 0xAB1C5ED5,
	0xD807AA98, 0x12835B01, 0x243185BE, 0x550C7DC3,
	0x72BE5D74, 0x80DEB1FE, 0x9BDC06A7, 0xC19BF174,
	0xE49B69C1, 0xEFBE4786, 0x0FC19DC6, 0x240CA1CC,
	0x2DE92C6F, 0x4A7484AA, 0x5CB0A9DC, 0x76F988DA,
	0x983E5152, 0xA831C66D, 0xB00327C8, 0xBF597FC7,
	0xC6E00BF3, 0xD5A79147, 0x06CA6351, 0x14292967,
	0x27B70A85, 0x2E1B2138, 0x4D2C6DFC, 0x53380D13,
	0x650A7354, 0x766A0ABB, 0x81C2C92E, 0x92722C85,
	0xA2BFE8A1, 0xA81A664B, 0xC24B8B70, 0xC76C51A3,
	0xD192E819, 0xD6990624, 0xF40E3585, 0x106AA070,
	0x19A4C116, 0x1E376C08, 0x2748774C, 0x34B0BCB5,
	0x391C0CB3, 0x4ED8AA4A, 0x5B9CCA4F, 0x682E6FF3,
	0x748F82EE, 0x78A5636F, 0x84C87814, 0x8CC70208,
	0x90BEFFFA, 0xA4506CEB, 0xBEF9A3F7, 0xC67178F2
];

rotr(x : int, n : int) -> int {
	bitOr(bitUshr(x, n), bitShl(x, 32 - n));
}

sha256Ch(x : int, y : int, z : int) -> int {
	bitXor(bitAnd(x, y), bitAnd(bitNot(x), z));
}

sha256Maj(x : int, y : int, z : int) -> int {
	bitXor(bitXor(bitAnd(x, y), bitAnd(x, z)), bitAnd(y, z));
}

sha256BigSigma0(x : int) -> int {
	bitXor(bitXor(rotr(x, 2), rotr(x, 13)), rotr(x, 22));
}

sha256BigSigma1(x : int) -> int {
	bitXor(bitXor(rotr(x, 6), rotr(x, 11)), rotr(x, 25));
}

sha256SmallSigma0(x : int) -> int {
	bitXor(bitXor(rotr(x, 7), rotr(x, 18)), bitUshr(x, 3));
}

sha256SmallSigma1(x : int) -> int {
	bitXor(bitXor(rotr(x, 17), rotr(x, 19)), bitUshr(x, 10));
}

padSha256Bytes(bytes : [int]) -> [int] {
	withMarker = concat(bytes, [0x80]);
	zeroPadLen = mod(56 - mod(length(withMarker), 64) + 64, 64);

	msgLen = length(bytes);
	high = bitUshr(msgLen, 29);
	low = bitShl(msgLen, 3);

	lengthBytes = [
		bitAnd(bitUshr(high, 24), 0xFF),
		bitAnd(bitUshr(high, 16), 0xFF),
		bitAnd(bitUshr(high, 8), 0xFF),
		bitAnd(high, 0xFF),
		bitAnd(bitUshr(low, 24), 0xFF),
		bitAnd(bitUshr(low, 16), 0xFF),
		bitAnd(bitUshr(low, 8), 0xFF),
		bitAnd(low, 0xFF)
	];

	concat(concat(withMarker, generate(0, zeroPadLen, \__ -> 0)), lengthBytes);
}

bytesToWordsBE(bytes : [int]) -> [int] {
	foldi(bytes, [], \i, acc, b -> {
		if (i % 4 == 0) {
			arrayPush(acc, b);
		} else {
			last = lastElement(acc, 0);
			replace(acc, length(acc) - 1, bitOr(bitShl(last, 8), b));
		}
	});
}

wordToBytesBE(word : int) -> [int] {
	[
		bitAnd(bitUshr(word, 24), 0xFF),
		bitAnd(bitUshr(word, 16), 0xFF),
		bitAnd(bitUshr(word, 8), 0xFF),
		bitAnd(word, 0xFF)
	];
}

wordsToBytesBE(words : [int]) -> [int] {
	fold(words, [], \acc, word -> concat(acc, wordToBytesBE(word)));
}

byteToHex(b : int) -> string {
	lpad(formatHex(bitAnd(b, 0xFF)), "0", 2);
}

bytesToHex(bytes : [int]) -> string {
	toLowerCase(fold(bytes, "", \acc, b -> acc + byteToHex(b)));
}

sha256WordsFromBytes(bytes : [int]) -> [int] {
	words = bytesToWordsBE(padSha256Bytes(bytes));
	doSha256Loop(words, 0, length(words), sha256Init);
}

sha256BytesFromBytes(bytes : [int]) -> [int] {
	wordsToBytesBE(sha256WordsFromBytes(bytes));
}

sha256HexFromBytes(bytes : [int]) -> string {
	bytesToHex(sha256BytesFromBytes(bytes));
}

doSha256Loop(words : [int], blockstart : int, nwords : int, h : [int]) -> [int] {
	if (blockstart < nwords) {
		w0 = concat(subrange(words, blockstart, 16), generate(16, 64, \__ -> 0));
		wr = map(w0, \w -> ref w);

		w = mapi(wr, \i, wref : ref int -> {
			if (i < 16) {
				^wref;
			} else {
				v = sha256SmallSigma1(^(wr[i - 2])) + ^(wr[i - 7]) + sha256SmallSigma0(^(wr[i - 15])) + ^(wr[i - 16]);
				wr[i] := v;
				v;
			}
		});

		a = ref h[0];
		b = ref h[1];
		c = ref h[2];
		d = ref h[3];
		e = ref h[4];
		f = ref h[5];
		g = ref h[6];
		hh = ref h[7];

		fori(0, 63, \i -> {
			t1 = ^hh + sha256BigSigma1(^e) + sha256Ch(^e, ^f, ^g) + sha256K[i] + w[i];
			t2 = sha256BigSigma0(^a) + sha256Maj(^a, ^b, ^c);

			hh := ^g;
			g := ^f;
			f := ^e;
			e := ^d + t1;
			d := ^c;
			c := ^b;
			b := ^a;
			a := t1 + t2;
		});

		doSha256Loop(words, blockstart + 16, nwords, [
			h[0] + ^a,
			h[1] + ^b,
			h[2] + ^c,
			h[3] + ^d,
			h[4] + ^e,
			h[5] + ^f,
			h[6] + ^g,
			h[7] + ^hh
		]);
	} else {
		h;
	}
}

hmacSha256Flow(input : string, key : string) -> string {
	blockSize = 64;
	keyBytes0 = string2utf8(key);

	keyBytes1 = if (length(keyBytes0) > blockSize) {
		sha256BytesFromBytes(keyBytes0);
	} else {
		keyBytes0;
	};

	paddedKey = concat(
		keyBytes1,
		generate(length(keyBytes1), blockSize, \__ -> 0)
	);

	iKeyPad = map(paddedKey, \b -> bitXor(b, 0x36));
	oKeyPad = map(paddedKey, \b -> bitXor(b, 0x5C));

	innerHash = sha256BytesFromBytes(concat(iKeyPad, string2utf8(input)));
	bytesToHex(sha256BytesFromBytes(concat(oKeyPad, innerHash)));
}

native hmacSha256Native : (input : string, key : string) -> string = FlowCrypto.hmacSha256;
hmacSha256Native(input : string, key : string) -> string {
	msg = "Warning: hmacSha256Native is not implemented for this target.";
	println(msg);
	hmacSha256Flow(input, key);
}

hmacSha256(input : string, key : string) -> string {
	hmacSha256Native(input, key);
}
