// AES-256-GCM encryption/decryption natives backed by FlowCrypto.java (Java/JAR target only).
//
// Encrypted token format: "{iv_hex}-{ciphertext_hex}-{tag_hex}"
//   IV  = 12 bytes (24 hex chars)
//   Tag = 16 bytes (32 hex chars)   — GCM authentication tag
//   '-' separator is URL-safe (RFC 3986 unreserved character).
//
// Key derivation: SHA-256(key_string) → 32-byte AES-256 key.
import string;

export {
	// Encrypt plaintext with AES-256-GCM.
	// Returns Some("{iv_hex}-{ciphertext_hex}-{tag_hex}") or None() on error.
	// We assume high-entopy hex key is used
	encryptAesGcm(data : string, key : string) -> Maybe<string>;

	// Decrypt a token produced by encryptAesGcm
	// Returns the Some(plaintext), or None() on failure / authentication error.
	decryptAesGcm(data : string, key : string) -> Maybe<string>;
}

// Encrypt plaintext with AES-256-GCM.
// Returns "{iv_hex}-{ciphertext_hex}-{tag_hex}" or "" on error.
native encryptAesGcmNative : (data : string, key : string) -> string = FlowCrypto.encryptAesGcm;

encryptAesGcm(data: string, key: string) -> Maybe<string> {
	result = encryptAesGcmNative(data, key);
	if (result == "") None()
	else Some(result)
}

// Decrypt a token produced by encryptAesGcm
// Returns the plaintext, or "Error in decryptAesGcmNative: <reason>" on any failure.
native decryptAesGcmNative : (data : string, key : string) -> string = FlowCrypto.decryptAesGcm;

decryptAesGcm(data: string, key: string) -> Maybe<string> {
	result = decryptAesGcmNative(data, key);
	if (startsWith(result, "Error in decryptAesGcmNative:")) None()
	else Some(result)
}

