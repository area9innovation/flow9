// AES-256-GCM encryption/decryption natives backed by FlowCrypto.java (Java/JAR target).
//
// Encrypted token format: "{iv_hex}-{ciphertext_hex}-{tag_hex}"
//   IV  = 12 bytes (24 hex chars)
//   Tag = 16 bytes (32 hex chars)   — GCM authentication tag
//   '-' separator is URL-safe (RFC 3986 unreserved character).
//
// Key derivation: SHA-256(key_string) → 32-byte AES-256 key.

export {
	// Encrypt plaintext with AES-256-GCM.
	// Returns "{iv_hex}-{ciphertext_hex}-{tag_hex}" or "" on error.
	native encryptAesGcm : (data : string, key : string) -> string = FlowCrypto.encryptAesGcm;

	// Decrypt a token produced by encryptAesGcm
	// Returns the plaintext, or "" on failure / authentication error.
	native decryptAesGcm : (data : string, key : string) -> string = FlowCrypto.decryptAesGcm;
}

encryptAesGcm(binarySource: string, algorithm: string) -> string {
	"";
}

decryptAesGcm(binarySource: string, algorithm: string) -> string {
	"";
}

