import ds/array;
import jwt_types;

export {
	// Creates a JWT token signed with the provided key and claims.
	//
	// The key parameter contains:
	//   - The algorithm (HS256, HS384, HS512, RS256, RS384, RS512, ES256, ES384, ES512)
	//   - The key material (secret for HMAC, private key for RSA/ECDSA in PEM PKCS8 format)
	//   - Optional kid (Key ID) which will be added to the JWT header if provided
	//
	// The claims parameter can be:
	//   - JwtClaimsJsonObject: a JsonObject containing the claims
	//   - JwtClaimsJsonObjectString: a JSON string representation of the claims
	//
	// Returns a JWT string on success, or a string beginning with "Error:" on failure.
	createJwt(key : JwtKey, claims : JwtClaims) -> string;

	// Verifies a JWT token using the provided key.
	//
	// The key parameter contains:
	//   - The algorithm (HS256, HS384, HS512, RS256, RS384, RS512, ES256, ES384, ES512)
	//   - For HMAC (HS*): the shared secret key (converted to UTF8 bytes)
	//   - For RSA (RS*): the public key in PEM format or JWK format with fields "n" and "e"
	//   - For ECDSA (ES*): the public key in PEM format or JWK format with fields "x", "y", and "crv"
	//
	// See https://datatracker.ietf.org/doc/html/rfc7518 for details on JWK format.
	//
	// Returns "OK" if the JWT is valid, otherwise an error message.
	verifyJwt(jwt : string, key : JwtKey) -> string;

	// Decodes and verifies a JWT token, extracting the claims.
	//
	// The jwtKey parameter is used to verify the JWT signature (see verifyJwt for details).
	// On success, calls callback with the decoded claims as a JwtClaimsJsonObject.
	// On failure, calls onError with an error message.
	decodeJwt(
		jwt : string,
		jwtKey : JwtKey,
		callback : (claims : JwtClaimsJsonObject) -> void,
		onError : (verify : string) -> void
	) -> void;

	getJwtClaimInt(claims : JwtClaimsJsonObject, claim : string) -> Maybe<int>;
	getJwtClaimString(claims : JwtClaimsJsonObject, claim : string) -> Maybe<string>;
}

createJwt(key : JwtKey, claims : JwtClaims) -> string {
	createJwtAlgorithmNative(
		either(getSigningKeyM(key), ""),
		switch (claims) {
			JwtClaimsJsonObject(c): json2string(c);
			JwtClaimsJsonObjectString(c): c;
		},
		jwtAlgorithm2string(key.alg),
		either(key.kid, "")
	)
}

verifyJwt(jwt : string, key : JwtKey) -> string {
	verifyJwtAlgorithmNative(
		jwt,
		either(getVerifyingKeyM(key), ""),
		jwtAlgorithm2string(key.alg)
	)
}

decodeJwt(
	jwt : string,
	jwtKey : JwtKey,
	callback : (claims : JwtClaimsJsonObject) -> void,
	onError : (verify : string) -> void
) -> void {
	eitherFn(
		getVerifyingKeyM(jwtKey),
		\key -> decodeJwtNative(
			jwt,
			jwtAlgorithm2string(jwtKey.alg),
			key,
			\jsonString -> switch (parseJson(jsonString)) {
				JsonObject(members): callback(JwtClaimsJsonObject(JsonObject(members)));
				default: onError("Wrong payload format");
			},
			onError
		),
		\-> onError("Can't get verifying key")
	)
}

native createJwtAlgorithmNative : (
	key: string,
	claimsJson: string,
	algorithm: string,
	kid: string,
) -> string = FlowJwt.createJwtAlgorithm;

native verifyJwtAlgorithmNative : (jwt : string, key : string, algorithm : string) -> string = FlowJwt.verifyJwtAlgorithm;

native decodeJwtNative : (
	jwt : string,
	alg : string,
	key : string,
	callback : (string) -> void,
	onError : (string) -> void
) -> void = FlowJwt.decodeJwt;

getJwtClaimInt(claims : JwtClaimsJsonObject, claim : string) -> Maybe<int> {
	getJsonMaybeValue(getJsonFieldValue(claims.claims, claim, JsonNull()), getJsonIntValue, 0)
}

getJwtClaimString(claims : JwtClaimsJsonObject, claim : string) -> Maybe<string> {
	getJsonMaybeValue(getJsonFieldValue(claims.claims, claim, JsonNull()), getJsonStringValue, "")
}

getSigningKeyM(key : JwtKey) -> Maybe<string> {
	switch (key : JwtKey) {
		HmacKey(secret, alg, __): Some(secret);
		RsaKeyPair(privateKey, __, __, __): privateKey;
		EcKeyPair(privateKey, __, __, __): privateKey;
	}
}

getVerifyingKeyM(key : JwtKey) -> Maybe<string> {
	switch (key : JwtKey) {
		HmacKey(secret, alg, __): Some(secret);
		RsaKeyPair(__, publicKey, __, __): maybeMap(publicKey, \pk -> publicKey2string(pk));
		EcKeyPair(__, publicKey, __, __): maybeMap(publicKey, \pk -> publicKey2string(pk));
	}
}

publicKey2string(key : JwtPublicKey) -> string {
	switch (key) {
		Pem(k): k;
		JwkRsa(__, __, __, __, __): jwk2string(key);
		JwkEc(__, __, __, __, __, __): jwk2string(key);
	}
}

jwk2string(jwk : Jwk) -> string {
	json2string(jwk2json(jwk))
}