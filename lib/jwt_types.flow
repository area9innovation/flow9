import formats/json/json;
export {
	// JWT Algorithm types - union of all supported signing algorithms
	JwtAlgorithm ::= HmacAlgorithm, RsaAlgorithm, EcAlgorithm;

	// HMAC-based algorithms (symmetric key cryptography)
	HmacAlgorithm ::= HS256, HS384, HS512;
		HS256();  // HMAC using SHA-256
		HS384();  // HMAC using SHA-384
		HS512();  // HMAC using SHA-512

	// RSA-based algorithms (asymmetric key cryptography)
	RsaAlgorithm ::= RS256, RS384, RS512;
		RS256();  // RSA using SHA-256
		RS384();  // RSA using SHA-384
		RS512();  // RSA using SHA-512

	// ECDSA-based algorithms (asymmetric key cryptography)
	EcAlgorithm ::= ES256, ES384, ES512;
		ES256();  // ECDSA using P-256 curve and SHA-256
		ES384();  // ECDSA using P-384 curve and SHA-384
		ES512();  // ECDSA using P-521 curve and SHA-512

	// Key material for JWT signing and verification
	JwtKey ::= HmacKey, RsaKeyPair, EcKeyPair;

	// JSON Web Key (JWK) formats for public keys
	Jwk ::= JwkEc, JwkRsa;

	// Public key representation (PEM or JWK format)
	JwtPublicKey ::= RsaPublicKey, EcPublicKey;

	// PEM-encoded public key (used by both RSA and ECDSA)
	Pem(key : string);

	// Symmetric key for HMAC algorithms (HS256, HS384, HS512)
	HmacKey(
		secret : string,           // Shared secret key (converted to UTF8 bytes)
		alg : HmacAlgorithm,       // HMAC algorithm to use
		kid : Maybe<string>        // Optional Key ID for JWT header
	);

	// RSA public key representation (PEM or JWK format)
	RsaPublicKey ::= Pem, JwkRsa;
		// RSA public key in JWK format (RFC 7517)
		JwkRsa(
			use : Maybe<string>,   // Optional key usage (e.g., "sig" for signature)
			alg : RsaAlgorithm,    // RSA algorithm
			kid : Maybe<string>,   // Optional Key ID
			n : string,            // Modulus (base64url-encoded)
			e : string             // Exponent (base64url-encoded)
		);

	// Asymmetric key pair for RSA algorithms (RS256, RS384, RS512)
	RsaKeyPair(
		privateKey : Maybe<string>,      // PEM-encoded private key in PKCS8 format (for signing)
		publicKey : Maybe<RsaPublicKey>, // Public key in PEM or JWK format (for verification)
		alg : RsaAlgorithm,              // RSA algorithm to use
		kid : Maybe<string>              // Optional Key ID for JWT header
	);

	// ECDSA public key representation (PEM or JWK format)
	EcPublicKey ::= Pem, JwkEc;
		// ECDSA public key in JWK format (RFC 7517)
		JwkEc(
			use : Maybe<string>,   // Optional key usage (e.g., "sig" for signature)
			alg : EcAlgorithm,     // ECDSA algorithm
			kid : Maybe<string>,   // Optional Key ID
			crv : string,          // Curve name (e.g., "P-256", "P-384", "P-521")
			x : string,            // X coordinate (base64url-encoded)
			y : string             // Y coordinate (base64url-encoded)
		);

	// Asymmetric key pair for ECDSA algorithms (ES256, ES384, ES512)
	EcKeyPair(
		privateKey : Maybe<string>,     // PEM-encoded private key in PKCS8 format (for signing)
		publicKey : Maybe<EcPublicKey>, // Public key in PEM or JWK format (for verification)
		alg : EcAlgorithm,              // ECDSA algorithm to use
		kid : Maybe<string>             // Optional Key ID for JWT header
	);

	// Converts a JwtAlgorithm to its string representation (e.g., HS256() -> "HS256").
	jwtAlgorithm2string(alg : JwtAlgorithm) -> string;

	// Parses a string into a JwtAlgorithm. Returns None if the string is not a valid algorithm name.
	string2jwtAlgorithm(alg : string) -> Maybe<JwtAlgorithm>;

	// Converts a JWK (JSON Web Key) to a JsonObject representation.
	jwk2json(jwk : Jwk) -> JsonObject;
}

// Helper to create an RSA key pair. Returns None if both keys are empty.
makeRsaKeyPair(privateKeyM : Maybe<string>, publicKeyM : Maybe<RsaPublicKey>, alg : RsaAlgorithm, kid : Maybe<string>) -> Maybe<JwtKey> {
	if (isSome(privateKeyM) || isSome(publicKeyM)) Some(RsaKeyPair(privateKeyM, publicKeyM, alg, kid)) else None();
}

// Helper to create an ECDSA key pair. Returns None if both keys are empty.
makeEcKeyPair(privateKeyM : Maybe<string>, publicKeyM : Maybe<EcPublicKey>, alg : EcAlgorithm, kid : Maybe<string>) -> Maybe<JwtKey> {
	if (isSome(privateKeyM) || isSome(publicKeyM)) Some(EcKeyPair(privateKeyM, publicKeyM, alg, kid)) else None();
}

// Converts a JwtAlgorithm to its string representation
jwtAlgorithm2string(alg : JwtAlgorithm) -> string {
	switch (alg) {
		HS256(): "HS256";
		HS384(): "HS384";
		HS512(): "HS512";
		RS256(): "RS256";
		RS384(): "RS384";
		RS512(): "RS512";
		ES256(): "ES256";
		ES384(): "ES384";
		ES512(): "ES512";
	}
}

// Parses a string into a JwtAlgorithm
string2jwtAlgorithm(alg : string) -> Maybe<JwtAlgorithm> {
	if (alg == "HS256") Some(HS256())
	else if (alg == "HS384") Some(HS384())
	else if (alg == "HS512") Some(HS512())
	else if (alg == "RS256") Some(RS256())
	else if (alg == "RS384") Some(RS384())
	else if (alg == "RS512") Some(RS512())
	else if (alg == "ES256") Some(ES256())
	else if (alg == "ES384") Some(ES384())
	else if (alg == "ES512") Some(ES512())
	else None()
}

// Converts a JWK to a JsonObject
jwk2json(jwk : Jwk) -> JsonObject {
	switch (jwk) {
		JwkRsa(use, alg, kid, n, e): {
			// Build required fields
			requiredFields = [
				Pair("kty", JsonString("RSA")),
				Pair("alg", JsonString(jwtAlgorithm2string(alg))),
				Pair("n", JsonString(n)),
				Pair("e", JsonString(e))
			];

			optionalFields = filtermap(
				[
					maybeMap(use, \u -> Pair("use", JsonString(u))),
					maybeMap(kid, \k -> Pair("kid", JsonString(k)))
				],
				idfn
			);
			JsonObject(concat(requiredFields, optionalFields))
		};
		JwkEc(use, alg, kid, crv, x, y): {
			// Build required fields
			requiredFields = [
				Pair("kty", JsonString("EC")),
				Pair("alg", JsonString(jwtAlgorithm2string(alg))),
				Pair("crv", JsonString(crv)),
				Pair("x", JsonString(x)),
				Pair("y", JsonString(y))
			];

			optionalFields = filtermap(
				[
					maybeMap(use, \u -> Pair("use", JsonString(u))),
					maybeMap(kid, \k -> Pair("kid", JsonString(k)))
				],
				idfn
			);
			JsonObject(concat(requiredFields, optionalFields))
		}
	}
}