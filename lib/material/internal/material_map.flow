import material/material;

export {
	// Return from the fn passed to mapMaterial:
	// MMapStop(m)  — use m as-is, do not recurse into its children.
	// MMapRecurse  — recurse into children and return the mapped node.
	MMapResult ::= MMapStop, MMapRecurse;
		MMapStop(mat : Material);
		MMapRecurse();

	// Pre-order tree mapper. fn is called on each node first.
	mapMaterial(m : Material, fn : (Material) -> MMapResult) -> Material;
}

mapMaterial(m : Material, fn : (Material) -> MMapResult) -> Material {
	r = \inner -> mapMaterial(inner, fn);
	switch (fn(m)) {
		MMapStop(mapped): mapped;
		MMapRecurse(): switch (m : Material) {
			MBorder(l, t, ri, b, inner): MBorder(l, t, ri, b, r(inner));
			MLines(ls): MLines(map(ls, r));
			MCols(cs): MCols(map(cs, r));
			MGroup(ms): MGroup(map(ms, r));
			MGrid(mls): MGrid(map(mls, \ms -> map(ms, r)));
			MLines2(m1, m2): MLines2(r(m1), r(m2));
			MCols2(m1, m2): MCols2(r(m1), r(m2));
			MGroup2(m1, m2): MGroup2(r(m1), r(m2));
			MBaselineCols(cs): MBaselineCols(map(cs, r));
			MBaselineLines(cs): MBaselineLines(map(cs, r));
			MBaselineCols2(m1, m2): MBaselineCols2(r(m1), r(m2));
			MBaselineLines2(m1, m2): MBaselineLines2(r(m1), r(m2));
			MMinimumGroup2(m1, m2): MMinimumGroup2(r(m1), r(m2));
			MSubtractGroup2(m1, m2): MSubtractGroup2(r(m1), r(m2));
			MCase(sizes, ms): MCase(map(sizes, r), map(ms, r));
			MBaselineOffset(of, inner): MBaselineOffset(of, r(inner));
			MAlpha(al, inner): MAlpha(al, r(inner));
			MCrop(topleft, wh, inner): MCrop(topleft, wh, r(inner));
			MCropSize(size, inner): MCropSize(r(size), r(inner));
			MVisible(val, inner): MVisible(val, r(inner));
			MShow(sh, inner): MShow(sh, r(inner));
			MAvailable(b, a): MAvailable(r(b), r(a));
			MShift(m1, d1): MShift(r(m1), r(d1));
			MRenderable(renderable, inner): MRenderable(renderable, r(inner));
			MConstruct(c, inner): MConstruct(c, r(inner));
			MDispose(d, inner): MDispose(d, r(inner));
			MInteractive(i, inner): MInteractive(i, r(inner));
			MCursor(kind, inner): MCursor(kind, r(inner));
			MFilter(filters, inner): MFilter(filters, r(inner));
			MAnimation(inner, keyframes, style): MAnimation(r(inner), keyframes, style);
			MAnimatedExpander(inner, expanded, style): MAnimatedExpander(r(inner), expanded, style);
			MAnimator(inner, trigger, style): MAnimator(r(inner), trigger, style);
			MTranslate(p, inner): MTranslate(p, r(inner));
			MRotate(degree, inner): MRotate(degree, r(inner));
			MOrigin(origin, inner): MOrigin(origin, r(inner));
			MCenter(inner): MCenter(r(inner));
			MCenterIn(inner, f): MCenterIn(r(inner), r(f));
			MCenterY(inner): MCenterY(r(inner));
			MCenterXIn(inner, f): MCenterXIn(r(inner), r(f));
			MCenterYIn(inner, f): MCenterYIn(r(inner), r(f));
			MCenterYInA(inner, f): MCenterYInA(r(inner), r(f));
			MCenterX(inner): MCenterX(r(inner));
			MFrame(mar, ri, s, inner): MFrame(mar, ri, s, r(inner));
			MScale(factor, inner): MScale(factor, r(inner));
			MBackground(depth, inner): MBackground(depth, r(inner));
			MDebug(c, inner): MDebug(c, r(inner));
			MTweak(style, c, s): MTweak(style, r(c), r(s));
			MMask(content, mask): MMask(r(content), r(mask));
			MExplicitTheme(target, light, state): MExplicitTheme(r(target), light, state);
			MScaleAvailable(factor, inner): MScaleAvailable(factor, r(inner));
			MFullWindow(fw, inner): MFullWindow(fw, r(inner));
			MFullScreen(fs, inner): MFullScreen(fs, r(inner));
			MShadow(z, inner): MShadow(z, r(inner));
			MShadowShape(z, inner, shape): MShadowShape(z, r(inner), shape);
			MLet(n, v, s): MLet(n, r(v), r(s));
			MLetMany(items, s): MLetMany(map(items, \p -> Pair(p.first, r(p.second))), r(s));
			MLetAvailable(n, s): MLetAvailable(n, r(s));
			MIf(c, t, e): MIf(c, r(t), r(e));
			MAttach(ghost, fn2): MAttach(r(ghost), \fm -> r(fn2(fm)));
			MFixSize(childm, size): MFixSize(r(childm), r(size));
			MSize(size, childm): MSize(r(size), r(childm));
			MSizeOf(inner): MSizeOf(r(inner));
			MZoom(box, target, keepAspect): MZoom(r(box), r(target), keepAspect);
			MZoomToFill(b, t, crop): MZoomToFill(r(b), r(t), crop);
			MDropSpot(onHover, onDrop, inner): MDropSpot(onHover, onDrop, r(inner));
			MDropSpot2(onHover, onDrop, inner, handle): MDropSpot2(onHover, onDrop, r(inner), handle);
			MClickable(inner, onClick): MClickable(r(inner), onClick);
			MMouseDownAround(point, down, hover, click, inner): MMouseDownAround(point, down, hover, click, r(inner));
			MInspect(inspectors, inner): MInspect(inspectors, r(inner));
			MSetFocusGroup(newParent, inner): MSetFocusGroup(newParent, r(inner));
			MComponent(state, fn2): MComponent(state, \focus -> r(fn2(focus)));
			MComponentGroup(inner, state): MComponentGroup(r(inner), state);
			MGetManager(fn2): MGetManager(\mgr -> r(fn2(mgr)));
			MGetFocusGroup(fn2): MGetFocusGroup(\fg -> r(fn2(fg)));
			MGetMaterial2Tropic(fn2): MGetMaterial2Tropic(\m2t -> fn2(\innerM, innerP -> m2t(r(innerM), innerP)));
			MDragDrop(id, inner, style): MDragDrop(id, r(inner), style);
			MRipple(inner): MRipple(r(inner));
			MRippleCircle(inner): MRippleCircle(r(inner));
			MAccess(prop, inner): MAccess(prop, r(inner));
			MPositionScale(ps, inner): MPositionScale(ps, r(inner));
			default: m;
		}
	};
}
