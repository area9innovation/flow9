import jwt;

// To run the test use java: 
//	build-jar tests/test_jwt.flow --run
//  or
//  flowc1 tests/test_jwt.flow jar=test_jwt.flow && java -jar test_jwt.jar

TestJwtVerificationResult(resSym : string, resPem : string, resJwk : string);
JwtTest(testName : string, expected : string, makeJwt : () -> string, algorithm : string, sym : string, pem : string, jwk : string);
JwtTest1(testName : string, expected : string, makeJwt : () -> string, jwtKey : JwtKey);

curve2Algorithm(curve : string) -> string {
	if (curve == "P-256") "ES256"
	else if (curve == "P-384") "ES384"
	else if (curve == "P-521") "ES512"
	else ""
}

// Parses a JWK JSON string into a Jwk structure. Returns None if parsing fails or required fields are missing.
string2jwk(jwk : string) -> Maybe<Jwk> {
	v = parseJson(jwk);
	maybeBind(
		getJsonMaybeValue(getJsonFieldValue(v, "kty", JsonNull()), getJsonStringValue, ""),
		\kty -> if (kty == "RSA") {
			maybeBind(
				string2jwtAlgorithm(getJsonStringField(v, "alg", "")),
				\alg -> switch (alg) {
					HmacAlgorithm(): None();
					EcAlgorithm(): None();
					RsaAlgorithm(): {
						n = getJsonStringField(v, "n", "");
						e = getJsonStringField(v, "e", "");
						if (n != "" && e != "") {
							Some(
								JwkRsa(
									getJsonMaybeValue(getJsonFieldValue(v, "use", JsonNull()), getJsonStringValue, ""),
									alg,
									getJsonMaybeValue(getJsonFieldValue(v, "kid", JsonNull()), getJsonStringValue, ""),
									n,
									e
								)
							)
						} else {
							None()
						}
					}
				}
			)
		} else if (kty == "EC") {
			maybeBind(
				string2jwtAlgorithm(getJsonStringField(v, "alg", curve2Algorithm(getJsonStringField(v, "crv", "")))),
				\alg -> switch (alg) {
					HmacAlgorithm(): None();
					RsaAlgorithm(): None();
					EcAlgorithm(): {
						crv = getJsonStringField(v, "crv", "");
						x = getJsonStringField(v, "x", "");
						y = getJsonStringField(v, "y", "");
						if (crv != "" && x != "" && y != "") {
							Some(
								JwkEc(
									getJsonMaybeValue(getJsonFieldValue(v, "use", JsonNull()), getJsonStringValue, ""),
									alg,
									getJsonMaybeValue(getJsonFieldValue(v, "kid", JsonNull()), getJsonStringValue, ""),
									crv,
									x,
									y
								)
							)
						} else {
							None()
						}
					}
				}
			)
		} else None()
	)
}

