			keyPemRSAv2,
			keyJwkRSAv2
		),
		JwtTest(
			"Verify we can create a key with a Private Key",
			"OK",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			"RS256",
			"",
			keyPemRSAv2,
			keyJwkRSAv2
		),
		JwtTest(
			"Create a key with kid",
			"OK",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "12345", 0),
			"RS256",
			"",
			keyPemRSAv2,
			keyJwkRSAv2
		),
		JwtTest(
			"Issue a jwt in the future",
			"The Token can't be used before",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 360),
			"RS256",
			"",
			keyPemRSAv2,
			keyJwkRSAv2
		),
		JwtTest(
			"Test that we get an error, not an exception when the public key JSON is invalid",
			"Can't parse JWK",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJSUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1M30.OaH9DCqCrf1chCXp8TqvanX5RwZqO5VhQCV2x3dsRo0EmPZpJH7OEilWOTCyWr1k12qMxyswr2LKU0OUw7nv0lPdUgsO4VpvEhO6s-Bw0q8aNXYPkLRMT7ML5qnxnJ0F1g_jYdOgEIrvJGvVOQs8bQcDJlfl9RRe0YRadNbGVJdaFtYniIgBykZthBDXVoKNFAhPXzvGWsrtUD-oFVhxxCg507mkxw8lTuTRt5jSLBo2KmJfJrBIg5UyNf8fDaJcSwQ5PyOUetpruV2w51uG43Uvqg35ABvaIVSi64LSIN78DxntOXp9cGIFzt077_UAdf82OWboXvw88H2FSpf5VA",
			"RS256",
			"",
			"",
			"{\"123\"}"
		),
		JwtTest(
			"The Token has expired ES256",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.yeFjg_EB233uGMO0sH0NoImjsD9GzD7qxvZGOo7srJ-mKd-01gY5hBtK5iSQYsIrJnxpfpfe6hg9xGsii-vdLg",
			"ES256",
			"",
			keyPemECDSA256,
			""
		),
		JwtTest(
			"The Token has expired ES384",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzM4NCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.Qk6K5Zo-6-4LRqjYToertiSwcs8Z6wSRClXOwTFCRn2lCYcZXx4_65oucVzGoWVmPa81U71Jlszk1xenU9voq52sLFKS2TI7m-INcgQlpf4ro15MTU6fm2FFGxCmeK-d",
			"ES384",
			"",
			keyPemECDSA384,
			""
		),
		JwtTest(
			"The Token has expired ES512",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzUxMiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.AGX8VWl6VBh9M_O5Zps1bfY8k6Vy-yoUSiBL2E_a2z0iopHJOf-W4RmWX31QJGizJoWRx591EhE_ut8drZNqrhlmAddfI3k2DA2rHG-tX3Dmvconx2-VU2Ss5UaQM8Rn5KrY0lV_joMh18RVk4Q03oYUk9wT5NXgU60WqlBdIhp5SO2J",
			"ES512",
			"",
			keyPemECDSA512,
			keyJwkECDSA512
		),
		JwtTest(
			"The wrong algorithm",
			"Wrong Algorithm",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzUxMiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.AGX8VWl6VBh9M_O5Zps1bfY8k6Vy-yoUSiBL2E_a2z0iopHJOf-W4RmWX31QJGizJoWRx591EhE_ut8drZNqrhlmAddfI3k2DA2rHG-tX3Dmvconx2-VU2Ss5UaQM8Rn5KrY0lV_joMh18RVk4Q03oYUk9wT5NXgU60WqlBdIhp5SO2J",
			"RS512",
			"",
			"",
			keyJwkECDSA512
		)
	];

	// iter(tests, \test -> verify(test.testName, test.expected, test.makeJwt, test.algorithm, test.sym, test.pem, test.jwk));

	verifyNewTypes = \testName, expected, makeJwt, jwtKey -> {
		jwt = makeJwt();
		result = verifyJwt(jwt, jwtKey);
		
		if (startsWith(result, expected)) {
			println("\nOK : " + testName);
		} else {
			haveFailed := arrayPush(^haveFailed, testName);
			println("\nFAILED : " + testName);
		}
		println("\t" + result);
	}

	emptyHsKey = HmacKey("", HS256(), None());
	tests1 = [
		JwtTest1(
			"Symmetric correct key",
			"OK",
			\-> makeJwtIat(0, hmacKey),
			hmacKey
		),
		JwtTest1(
			"Symmetric key, encrypted with empty secret",
			"The token was expected",
			\-> makeJwtIat(0, emptyHsKey),
			emptyHsKey
		),
		JwtTest1(
			"Symmetric key, verified with wrong secret",
			"The Token's Signature resulted invalid",
			\-> makeJwtIat(0, hmacKey),
			HmacKey(hmacKey with secret = "another secret")
		),
		JwtTest1(
			"Symmetric key, verified with empty secret",
			"The Token's Signature resulted invalid",
			\-> makeJwtIat(0, hmacKey),
			emptyHsKey
		),
		JwtTest1(
			"Symmetric key, inconsistent algorithm used for verification",
			"The provided Algorithm doesn't match",
			\-> makeJwtIat(0, hmacKey),
			HmacKey(hmacKey with alg = HS512())
		),

		JwtTest1(
			"Symmetric key, none-symmetric key used for verification",
			"The provided Algorithm doesn't match",
			\-> makeJwtIat(0, hmacKey),
			RsaKeyPair(None(), Some(Pem(keyPemRSA)), RS256(), None())
		),
		JwtTest1(
			"RSA correct key",
			"OK",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), Some(Pem(keyPemRSAv2)), RS256(), None())
		),
		JwtTest1(
			"RSA correct key, jwk used",
			"OK",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), Some(jwkRSAv2), RS256(), None())
		),
		JwtTest1(
			"RSA correct key, jwk used with inconsistent algorithm",
			"The provided Algorithm doesn't match",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), Some(jwkRSAv2), RS512(), None())
		),
		JwtTest1(
			"RSA correct key, jwk used with wrong n",
			"The Token's Signature resulted invalid",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), Some(jwkRSAv2WrongN), RS256(), None())
		),
		JwtTest1(
			"RSA key, inconsistent algorithm",
			"The provided Algorithm doesn't match",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), Some(Pem(keyPemRSAv2)), RS384(), None())
		),
		JwtTest1(
			"RSA key, encrypted with empty secret",
			"The input is not a valid",
			\-> makeRsJwtIat("", "", 0),
			RsaKeyPair(None(), Some(Pem(keyPemRSAv2)), RS384(), None())
		),
		JwtTest1(
			"RSA key, verified with empty secret",
			"java.security.InvalidKeyException: Missing key encoding",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			RsaKeyPair(None(), None(), RS384(), None())
		),
		JwtTest1(
			"RSA key, verified with symmetric key",
			"The provided Algorithm doesn't match",
			\-> makeRsJwtIat(keyPrivatePemPkcs8RSAv2, "", 0),
			hmacKey
		),

		JwtTest1(
			"The Token has expired ES256",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzI1NiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.yeFjg_EB233uGMO0sH0NoImjsD9GzD7qxvZGOo7srJ-mKd-01gY5hBtK5iSQYsIrJnxpfpfe6hg9xGsii-vdLg",
			EcKeyPair(None(), Some(Pem(keyPemECDSA256)), ES256(), None())
		),
		JwtTest1(
			"The Token has expired ES384",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzM4NCJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.Qk6K5Zo-6-4LRqjYToertiSwcs8Z6wSRClXOwTFCRn2lCYcZXx4_65oucVzGoWVmPa81U71Jlszk1xenU9voq52sLFKS2TI7m-INcgQlpf4ro15MTU6fm2FFGxCmeK-d",
			EcKeyPair(None(), Some(Pem(keyPemECDSA384)), ES384(), None())
		),
		JwtTest1(
			"The Token has expired ES512",
			"The Token has expired",
			\-> "eyJ0eXAiOiJKV1QiLCJhbGciOiJFUzUxMiJ9.eyJzdWIiOiIxMjM0NTY3ODkwIiwibmFtZSI6IkpvaG4gRG9lIiwiYWRtaW4iOnRydWUsImlhdCI6MTcyNTYwNTE1MywiZXhwIjoxNzI3NjA4NzUzfQ.AGX8VWl6VBh9M_O5Zps1bfY8k6Vy-yoUSiBL2E_a2z0iopHJOf-W4RmWX31QJGizJoWRx591EhE_ut8drZNqrhlmAddfI3k2DA2rHG-tX3Dmvconx2-VU2Ss5UaQM8Rn5KrY0lV_joMh18RVk4Q03oYUk9wT5NXgU60WqlBdIhp5SO2J",
			EcKeyPair(None(), Some(Pem(keyPemECDSA512)), ES512(), None())
		),
		JwtTest1(
			"Correct ES256 key",
			"OK",
			\-> makeJwtIat(0, EcKeyPair(Some(keyPrivatePemECDSA256), None(), ES256(), None())),
			EcKeyPair(None(), Some(Pem(keyPublicPemECDSA256)), ES256(), None())
		),
		JwtTest1(
			"Correct ES256 key, verification with JwkEc",
			"OK",
			\-> makeJwtIat(0, EcKeyPair(Some(keyPrivatePemECDSA256), None(), ES256(), None())),
			EcKeyPair(None(), Some(keyJwkECDSA256), ES256(), None())
		),
		JwtTest1(
			"Correct ES256 key, inconsistent algorithm",
			"The provided Algorithm doesn't match",
			\-> makeJwtIat(0, EcKeyPair(Some(keyPrivatePemECDSA256), None(), ES256(), None())),
			EcKeyPair(None(), Some(keyJwkECDSA256), ES384(), None())
		),
		JwtTest1(
			"Correct ES256 key, RSA private pem used for encryption",
			"The input is not a valid",
			\-> makeJwtIat(0, EcKeyPair(Some(keyPrivatePemPkcs8RSAv2), None(), ES256(), None())),
			EcKeyPair(None(), Some(keyJwkECDSA256), ES256(), None())
		),
		JwtTest1(
			"Correct ES256 key, wrong pem used for verification",
			"The Token's Signature resulted invalid",
			\-> makeJwtIat(0, EcKeyPair(Some(keyPrivatePemECDSA256), None(), ES256(), None())),
			EcKeyPair(None(), Some(Pem(keyPemECDSA256)), ES256(), None())
		)
	];

	iter(tests1, \test -> verifyNewTypes(test.testName, test.expected, test.makeJwt, test.jwtKey));

	quit(if (^haveFailed != []) {
		println("Next tests failed:");
		iter(^haveFailed, println);
		1;
	} else {
		println("All tests passed");
		0;
	});
}
