	haveFailed : ref [string] = ref [];

	verify = \testName, expected, makeJwt, algorithm, sym, pem, jwk -> {
		jwt = makeJwt();
		result : TestJwtVerificationResult = eitherMap(
			string2jwtAlgorithm(algorithm),
			\alg -> switch (alg) {
				HmacAlgorithm(): TestJwtVerificationResult(verifyJwt(jwt, HmacKey(sym, alg, None())), "", "");
				RsaAlgorithm(): TestJwtVerificationResult(
					"",
					if (pem == "") "" else verifyJwt(jwt, RsaKeyPair(None(), Some(Pem(pem)), alg, None())),
					if (jwk == "") "" else eitherMap(
						string2jwk(jwk),
						\j -> switch (j) {
							JwkRsa(__, __, __, __, __): verifyJwt(jwt, RsaKeyPair(None(), Some(j), alg, None()));
							JwkEc(__, __, __, __, __, __): "Wrong Algorithm";
						},
						"Can't parse JWK"
					)
				);
				EcAlgorithm(): TestJwtVerificationResult(
					"",
					if (pem == "") "" else verifyJwt(jwt, EcKeyPair(None(), Some(Pem(pem)), alg, None())),
					if (jwk == "") "" else eitherMap(
						string2jwk(jwk),
						\j -> switch (j) {
							JwkRsa(__, __, __, __, __): "Wrong Algorithm";
							JwkEc(__, __, __, __, __, __): verifyJwt(jwt, EcKeyPair(None(), Some(j), alg, None()));
						},
						"Can't parse JWK"
					)
				);
			},
			TestJwtVerificationResult("", "", "")
		)
		resPem = result.resPem;
		resJwk = result.resJwk;
		resSym = result.resSym;

		if (
			(resPem != "" || resJwk != "" || resSym != "") && 
			(resPem == "" || startsWith(resPem, expected)) && 
			(resJwk == "" || startsWith(resJwk, expected)) && 
			(resSym == "" || startsWith(resSym, expected))
		) {
			println("\nOK : " + testName);
		} else {
			haveFailed := arrayPush(^haveFailed, testName);
			println("\nFAILED : " + testName);
			println(pem);
			println(jwk);
		}
		//println("\t" + algorithm + " JWT: " + jwt);
		println("\t" + algorithm + " Sym format: " + resSym); // Symmetric key format
		println("\t" + algorithm + " PEM format: " + resPem);
		println("\t" + algorithm + " JWK format: " + resJwk);
	}


	hs256Key = "someKey";
	hmacKey = HmacKey(hs256Key, HS256(), None());

	nowSeconds: int = floor(timestamp() / 1000.0);

	makeJwtIat = \addIat: int, key: JwtKey -> {
		createJwt(key, JsonObject([Pair("sub", JsonString("1234567890")), Pair("name", JsonString("John Doe")), Pair("admin", JsonBool(true)), Pair("iat", JsonDouble(i2d(nowSeconds + addIat)))]));
	};

	// Make an JWT that is issued 10 minutes hour ago, and expire now + addIat
	makeHsJwtExp = \addExp: int -> {
		createJwt(hmacKey, JsonObject([Pair("sub", JsonString("1234567890")), Pair("name", JsonString("John Doe")), Pair("admin", JsonBool(true)), Pair("iat", JsonDouble(i2d(nowSeconds - 600))), Pair("exp", JsonDouble(i2d(nowSeconds + addExp)))]));
	};

	makeRsJwtIat = \key: string, kid: string, addIat: int -> {
		jwt = createJwt(RsaKeyPair(Some(key), None(), RS256(), Some(kid)), JsonObject([Pair("sub", JsonString("1234567890")), Pair("name", JsonString("John Doe")), Pair("admin", JsonBool(true)), Pair("iat", JsonDouble(i2d(nowSeconds + addIat)))]));
		if (startsWith(jwt, "Error:")) {
			println("\tcreateJwt failed: " + jwt);
		} else {
			println("\tRS jwt: " + jwt);
		};
		jwt;
	};
