import math/sha256;
import string;

main() {
	// SHA-256 test vectors
	h1 = sha256("abc");
	println("sha256(\"abc\") = " + h1);
	if (h1 == "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad") {
		println("PASS: sha256(abc)");
	} else {
		println("FAIL: sha256(abc), expected ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad");
	}

	h2 = sha256("");
	println("sha256(\"\") = " + h2);
	if (h2 == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855") {
		println("PASS: sha256(empty)");
	} else {
		println("FAIL: sha256(empty)");
	}

	// HMAC-SHA256 RFC 4231 test case 1: key = 0x0b*20, data = "Hi There"
	key1 = strRepeat("\u000b", 20);
	h3 = hmacSha256("Hi There", key1);
	println("hmacSha256(\"Hi There\") = " + h3);
	if (h3 == "b0344c61d8db38535ca8afceaf0bf12b881dc200c9833da726e9376c2e32cff7") {
		println("PASS: hmacSha256(Hi There)");
	} else {
		println("FAIL: hmacSha256(Hi There)");
	}

	// HMAC-SHA256 RFC 4231 test case 2: key = "Jefe", data = "what do ya want for nothing?"
	h4 = hmacSha256("what do ya want for nothing?", "Jefe");
	println("hmacSha256(\"Jefe\") = " + h4);
	if (h4 == "5bdcc146bf60754e6a042426089575c75a003f089d2739839dec58b964ec3843") {
		println("PASS: hmacSha256(Jefe)");
	} else {
		println("FAIL: hmacSha256(Jefe)");
	}
}
